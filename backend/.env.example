# Railway backend service
# Railway automatically sets PORT.
# No required environment variables for the current SQLite prototype.
PORT=8000


# Performance toggles — v1.5.4
BOTTLE_PROCESSING_MODE=fast
MAX_IMAGE_DIM=720
ENABLE_OVERLAYS=true
ENABLE_REAL_DL=false
DETAILED_PARAMETER_TRACE=false

# Turn these on only for deeper analysis/demo:
# 
# ENABLE_REAL_DL=true
# DETAILED_PARAMETER_TRACE=true
